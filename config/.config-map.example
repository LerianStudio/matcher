# Matcher — Bootstrap-Only Configuration (requires restart)
#
# Common settings that require a container/pod restart to take effect.
# For the full list of bootstrap-only keys, see the systemplane key definitions
# in internal/bootstrap/systemplane_keys_*.go (any key with ApplyBootstrapOnly).
# Everything else is hot-reloadable at runtime via the canonical lib-commons v5
# systemplane admin API (management-plane surface, intentionally excluded from
# the public OpenAPI spec):
#
#   GET  /system/matcher             — list all keys (inline schema metadata)
#   GET  /system/matcher/:key        — read a single key
#   PUT  /system/matcher/:key        — write a single key
#
# See github.com/LerianStudio/lib-commons/v5/commons/systemplane/admin for the
# full HTTP surface. The v4 /v1/system/configs[...] paths and the /schema,
# /history, /reload sub-endpoints were removed in the v5 migration.
#
# For local development with docker-compose, you don't need this file at all.
# All defaults are baked into the binary and match the docker-compose setup.
#
# For production (Kubernetes), map these as a ConfigMap or Secret and inject
# as environment variables into the pod spec.

# ── Application ──────────────────────────────────────────────────────────────
# Environment name. Affects security enforcement (production disables Swagger,
# forces rate limiting). Values: development, staging, production.
ENV_NAME=development

# Deployment mode — informational only. Surfaces in the /readyz response
# envelope's "deployment_mode" field and seeds logger configuration defaults.
# Does NOT gate TLS enforcement. Values: local, byoc, saas.
DEPLOYMENT_MODE=local

# ── TLS Enforcement (per-stack, opt-in) ─────────────────────────────────────
# Each infra stack has an independent TLS_REQUIRED boolean flag. When true,
# bootstrap verifies the stack's connection configuration declares TLS BEFORE
# any infrastructure connection opens — otherwise it aborts with a clear
# error naming the offending stack. When false (default), the stack is
# unenforced regardless of its configured posture.
#
# Stacks are orthogonal: enforce only what you need. Recommended production
# posture is to enforce every stack (uncomment and set all five to true).
#
# POSTGRES_TLS_REQUIRED=false           # require POSTGRES_SSLMODE != "disable"
# POSTGRES_REPLICA_TLS_REQUIRED=false   # require POSTGRES_REPLICA_SSLMODE != "disable" (only when a distinct replica is configured)
# REDIS_TLS_REQUIRED=false              # require REDIS_TLS=true
# RABBITMQ_TLS_REQUIRED=false           # require RABBITMQ_URI=amqps
# OBJECT_STORAGE_TLS_REQUIRED=false     # require OBJECT_STORAGE_ENDPOINT to be https:// (empty = AWS default HTTPS, accepted)

# Log level. BOOTSTRAP-ONLY — runtime swapping is NOT implemented; changing
# this requires a process restart. Values: debug, info, warn, error.
LOG_LEVEL=info

# ── Tenancy ─────────────────────────────────────────────────────────────────
# Default tenant identity used when auth is disabled or claims are unavailable.
DEFAULT_TENANT_ID=11111111-1111-1111-1111-111111111111
DEFAULT_TENANT_SLUG=default

# ── Server ───────────────────────────────────────────────────────────────────
# HTTP listen address. Change requires server restart.
SERVER_ADDRESS=:4018

# Maximum HTTP request body size is runtime-managed via systemplane.
# Configure `server.body_limit_bytes` via PUT /system/matcher/server.body_limit_bytes instead.
#
# Rate limiting is runtime-managed via systemplane. Tier keys (all under
# /system/matcher):
#   rate_limit.max / .expiry_sec                — global tier (tenant API)
#   rate_limit.export_max / .export_expiry_sec  — export endpoints
#   rate_limit.dispatch_max / .dispatch_expiry_sec — dispatch endpoints
#   rate_limit.admin_max / .admin_expiry_sec    — admin plane (/system)
# The admin tier is scoped separately so admin traffic and tenant traffic
# cannot starve each other under fail-open Redis outage.

# TLS — only needed when terminating TLS at the application level.
# Most deployments terminate TLS at the ingress/load balancer.
# SERVER_TLS_CERT_FILE=
# SERVER_TLS_KEY_FILE=

# Set to true when TLS is terminated by an upstream proxy (enables HSTS).
TLS_TERMINATED_UPSTREAM=false

# Comma-separated trusted proxy CIDRs for client IP resolution.
# TRUSTED_PROXIES=

# ── Authentication ───────────────────────────────────────────────────────────
# Enable lib-auth JWT middleware.
# REQUIRED for production. Only set to false for isolated local development.
PLUGIN_AUTH_ENABLED=true

# Auth service address for token validation.
# PLUGIN_AUTH_ADDRESS=http://localhost:8081

# JWT signing secret. REQUIRED when PLUGIN_AUTH_ENABLED=true.
# SECURITY: Use a strong random secret (minimum 32 bytes) in production.
# AUTH_JWT_SECRET=

# ── Observability ────────────────────────────────────────────────────────────
# OpenTelemetry. Disabled by default. Enable for traces/metrics collection.
ENABLE_TELEMETRY=false
OTEL_RESOURCE_SERVICE_NAME=matcher
OTEL_LIBRARY_NAME=github.com/LerianStudio/matcher
OTEL_RESOURCE_SERVICE_VERSION=1.1.0
OTEL_RESOURCE_DEPLOYMENT_ENVIRONMENT=development
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317

# Database metrics scrape interval (seconds).
DB_METRICS_INTERVAL_SEC=15

# ── Database ─────────────────────────────────────────────────────────────────
# Filesystem path to SQL migrations used during startup.
MIGRATIONS_PATH=migrations

# ── Infrastructure ───────────────────────────────────────────────────────────
# Startup timeout for connecting to Postgres, Redis, RabbitMQ, and S3.
INFRA_CONNECT_TIMEOUT_SEC=30

# Per-check /readyz probe timeout in milliseconds. Default 800ms keeps
# the handler wall-clock below kubelet's default timeoutSeconds=1. Prefer
# this over the deprecated HEALTH_CHECK_TIMEOUT_SEC (5s legacy default).
# HEALTH_CHECK_TIMEOUT_MS=800

# ── Idempotency ──────────────────────────────────────────────────────────────
# Optional HMAC secret for signing idempotency keys before storing them.
# SECURITY: Use a strong random secret (minimum 32 bytes) in production.
# IDEMPOTENCY_HMAC_SECRET=

# ── Fetcher Bridge (verified-artifact retrieval) ─────────────────────────────
# Master key shared with the Fetcher service. Matcher derives two keys
# locally via HKDF-SHA256 using the contract-locked contexts
# "fetcher-external-hmac-v1" and "fetcher-external-aes-v1" to verify
# completed-artifact integrity and decrypt their payloads. Must be
# base64-encoded and decode to at least 32 bytes.
#
# Generate a unique value per environment:
#   openssl rand -base64 32 | tr -d '\n'
#
# Empty soft-disables verified-artifact retrieval — the T-001 trusted
# stream intake path still works, but the T-002 pipeline
# (retrieve → verify → custody) is skipped. Populate before enabling the
# Fetcher bridge worker (T-003) against a real Fetcher instance.
#
# SECURITY: treat as a secret. Never log, never commit. Bootstrap-only:
# rotation requires a service restart because derived keys are cached
# for the process lifetime.
# APP_ENC_KEY=

# ── Fetcher Bridge (T-003 DoS guard) ─────────────────────────────────────────
# Maximum Fetcher extraction payload size in bytes. Caps FlattenFetcherJSON
# materialisation so a malformed or hostile Fetcher cannot OOM the matcher
# pod with a multi-GB response. Default 2 GiB (2147483648). Tighten for
# smaller working-set deployments. Bootstrap-only: changing mid-flight while
# a long-running flatten is in progress would create ambiguous behaviour.
# Bounded validator: must be between 1 MiB (1048576) and 16 GiB (17179869184).
# FETCHER_MAX_EXTRACTION_BYTES=2147483648

# NOTE: The following Fetcher tunables are NOT listed here because they are
# runtime-mutable via the systemplane (ApplyWorkerReconcile or ApplyLiveRead
# + MutableAtRuntime=true). Operate them via the v5 admin API:
#   PUT /system/matcher/fetcher.bridge_interval_sec                  (bounds [5, 3600])
#   PUT /system/matcher/fetcher.bridge_batch_size                    (bounds [1, 10000])
#   PUT /system/matcher/fetcher.bridge_tenant_concurrency            (positive int; default 4)
#   PUT /system/matcher/fetcher.bridge_stale_threshold_sec           (bounds [60, 86400])
#   PUT /system/matcher/fetcher.bridge_retry_max_attempts            (bounds [1, 100])
#   PUT /system/matcher/fetcher.custody_retention_sweep_interval_sec (bounds [60, 86400])
#   PUT /system/matcher/fetcher.custody_retention_grace_period_sec   (bounds [0, 604800])
# The tenant-concurrency knob caps per-pollCycle tenant fan-out for the Fetcher
# bridge worker; the corresponding env var FETCHER_BRIDGE_TENANT_CONCURRENCY
# seeds bootstrap defaults only — runtime changes flow through the systemplane
# key above via UpdateRuntimeConfig.
# .config-map.example documents BOOTSTRAP-only env vars (those that require
# a service restart). Keep hot-reloadable systemplane keys out of this file.

# ── M2M (Machine-to-Machine) ─────────────────────────────────────────────────
# Target service name for Secrets Manager M2M credential path.
# Path: tenants/{env}/{tenantOrgID}/{applicationName}/m2m/{targetService}/credentials
M2M_TARGET_SERVICE=fetcher

# AWS region for Secrets Manager API calls. When empty, the AWS SDK uses its
# default chain (env, config file, instance metadata).
# AWS_REGION=

# ── Exception Dispatch (webhook) ─────────────────────────────────────────────
# Webhook signing. Matcher signs outgoing exception-dispatch webhooks with an
# HMAC-SHA256 shared secret delivered in the X-Signature-256 header. In
# production deployments (ENV_NAME=production), the dispatcher refuses to send
# unsigned payloads: if a shared secret has not been configured, the dispatch
# returns ErrWebhookMissingSharedSecret instead of warning and proceeding.
#
# Migration note (SEC-27): the pre-v5-lib-commons behaviour warned but sent
# unsigned. Deployments upgrading to this build must either configure a shared
# secret before routing webhook dispatches, or — if still in rollout — keep
# webhook destinations disabled until signing is wired in. There is no env-var
# override of this default; the intent is that misconfiguration is visible
# from the first dispatch attempt rather than hidden behind a log line.

# ── Systemplane ──────────────────────────────────────────────────────────────
# Backend store for runtime configuration. Default: postgres (reuses the
# application Postgres DSN). Set to "mongodb" for a Mongo-backed store.
# SYSTEMPLANE_BACKEND=postgres

# Override the connection DSN for the systemplane store. When unset, the
# application's primary Postgres DSN is used.
# SYSTEMPLANE_POSTGRES_DSN=

# Optional Postgres backend overrides for the systemplane store.
# SYSTEMPLANE_POSTGRES_SCHEMA=
# SYSTEMPLANE_POSTGRES_ENTRIES_TABLE=
# SYSTEMPLANE_POSTGRES_HISTORY_TABLE=
# SYSTEMPLANE_POSTGRES_REVISION_TABLE=
# SYSTEMPLANE_POSTGRES_NOTIFY_CHANNEL=

# MongoDB backend settings. Only used when SYSTEMPLANE_BACKEND=mongodb.
# SYSTEMPLANE_MONGODB_URI=mongodb://localhost:27017
# SYSTEMPLANE_MONGODB_DATABASE=matcher_systemplane
# SYSTEMPLANE_MONGODB_ENTRIES_COLLECTION=entries
# SYSTEMPLANE_MONGODB_HISTORY_COLLECTION=history
# SYSTEMPLANE_MONGODB_WATCH_MODE=change_stream
# SYSTEMPLANE_MONGODB_POLL_INTERVAL_SEC=30

# REQUIRED: AES-256-GCM master key for encrypting secret config values.
# Generate a unique value per environment:
#   openssl rand -base64 32 | tr -d '\n'
# SECURITY: The development default (used in docker-compose.yml) is
# explicitly blocked in production by validateProductionConfig.
# SYSTEMPLANE_SECRET_MASTER_KEY=
