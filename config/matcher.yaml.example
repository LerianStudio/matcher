# Matcher Configuration
# =====================
# This file contains runtime-configurable settings for the Matcher service.
# Changes to [hot-reloadable] settings take effect without restart.
# Settings marked [restart-required] need a service restart.
#
# Override hierarchy: Go defaults -> this file -> environment variables
# Environment variables ALWAYS win (for K8s secrets and deploy-time overrides).
#
# Secrets (passwords, tokens, keys, certs) must NEVER appear in this file.
# Use environment variables for all sensitive values.
#
# YAML override env vars use the MATCHER_ prefix with flattened keys:
#   MATCHER_APP_LOG_LEVEL=debug          -> app.log_level
#   MATCHER_RATE_LIMIT_MAX=200           -> rate_limit.max
#   MATCHER_EXPORT_WORKER_PAGE_SIZE=2000 -> export_worker.page_size

# --------------------------------------------------------------------------
# Application
# --------------------------------------------------------------------------
app:
  # Log level: debug, info, warn, error, fatal [restart-required]
  log_level: "info"

# --------------------------------------------------------------------------
# Server [restart-required]
# --------------------------------------------------------------------------
server:
  # Maximum HTTP request body size in bytes [restart-required]
  body_limit_bytes: 104857600  # 100 MB

  # Comma-separated allowed CORS origins [restart-required]
  cors_allowed_origins: "http://localhost:3000"
  # Comma-separated allowed CORS methods [restart-required]
  cors_allowed_methods: "GET,POST,PUT,PATCH,DELETE,OPTIONS"
  # Comma-separated allowed CORS headers [restart-required]
  cors_allowed_headers: "Origin,Content-Type,Accept,Authorization,X-Request-ID"
  # Comma-separated trusted proxy addresses/CIDRs for client IP resolution [restart-required]
  trusted_proxies: ""

# --------------------------------------------------------------------------
# PostgreSQL Connection Pool
# --------------------------------------------------------------------------
postgres:
  # Maximum open connections to the database [restart-required]
  max_open_connections: 25
  # Maximum idle connections in the pool [restart-required]
  max_idle_connections: 5
  # Maximum lifetime of a connection in minutes [restart-required]
  conn_max_lifetime_mins: 30
  # Maximum idle time of a connection in minutes [restart-required]
  conn_max_idle_time_mins: 5
  # Connection establishment timeout in seconds [restart-required]
  connect_timeout_sec: 10
  # Query execution timeout in seconds [restart-required]
  query_timeout_sec: 30

# --------------------------------------------------------------------------
# Redis Connection Pool [restart-required]
# --------------------------------------------------------------------------
redis:
  # Maximum number of connections in the pool [restart-required]
  pool_size: 10
  # Minimum number of idle connections maintained [restart-required]
  min_idle_conn: 2
  # Read operation timeout in milliseconds [restart-required]
  read_timeout_ms: 3000
  # Write operation timeout in milliseconds [restart-required]
  write_timeout_ms: 3000
  # Connection dial timeout in milliseconds [restart-required]
  dial_timeout_ms: 5000

# --------------------------------------------------------------------------
# RabbitMQ [restart-required]
# --------------------------------------------------------------------------
rabbitmq:
  # Allow insecure (HTTP) health check endpoint [restart-required]
  # Must be false in production
  allow_insecure_health_check: false

# --------------------------------------------------------------------------
# Swagger / API Documentation [restart-required]
# --------------------------------------------------------------------------
swagger:
  # Enable Swagger UI (force-disabled in production) [restart-required]
  enabled: false
  # Override spec host (empty = use request host) [restart-required]
  # Set to an explicit hostname behind reverse proxies / API gateways
  host: ""
  # Comma-separated schemes: http, https [restart-required]
  schemes: "https"

# --------------------------------------------------------------------------
# Telemetry [mixed]
# --------------------------------------------------------------------------
telemetry:
  # OpenTelemetry resource service name [restart-required]
  service_name: "matcher"
  # OpenTelemetry instrumentation library name [restart-required]
  library_name: "github.com/LerianStudio/matcher"
  # Service version reported to telemetry collector [restart-required]
  service_version: "1.0.0"
  # Deployment environment: development, staging, production [restart-required]
  deployment_env: "development"

  # Database connection pool metrics collection interval in seconds [restart-required]
  # Lower values = more granular monitoring but increased overhead
  db_metrics_interval_sec: 15

# --------------------------------------------------------------------------
# Rate Limiting [hot-reloadable]
# --------------------------------------------------------------------------
rate_limit:
  # Enable global rate limiting (force-enabled in production) [hot-reloadable]
  enabled: true
  # Maximum requests per window [hot-reloadable]
  max: 100
  # Rate limit window duration in seconds [hot-reloadable]
  expiry_sec: 60

  # Export endpoint rate limiting [hot-reloadable]
  export_max: 10
  export_expiry_sec: 60

  # Dispatch endpoint rate limiting [hot-reloadable]
  dispatch_max: 50
  dispatch_expiry_sec: 60

# --------------------------------------------------------------------------
# Infrastructure Health [restart-required]
# --------------------------------------------------------------------------
infrastructure:
  # Per-dependency readiness timeout in seconds [hot-reloadable]
  health_check_timeout_sec: 5

# --------------------------------------------------------------------------
# Callback Rate Limiting [restart-required]
# --------------------------------------------------------------------------
callback_rate_limit:
  # Maximum callbacks per external system per minute [restart-required]
  # Each external system (JIRA, WEBHOOK, SERVICENOW, etc.) gets its own budget
  per_minute: 60

# --------------------------------------------------------------------------
# Idempotency [restart-required]
# --------------------------------------------------------------------------
idempotency:
  # How long failed idempotency keys remain blocked before retry [restart-required]
  retry_window_sec: 300  # 5 minutes
  # How long completed idempotency keys remain cached [restart-required]
  success_ttl_hours: 168  # 7 days

# --------------------------------------------------------------------------
# Deduplication [restart-required]
# --------------------------------------------------------------------------
deduplication:
  # TTL for deduplication keys in Redis [restart-required]
  ttl_sec: 3600  # 1 hour

# --------------------------------------------------------------------------
# Webhook [restart-required]
# --------------------------------------------------------------------------
webhook:
  # Default HTTP timeout for webhook dispatches in seconds [restart-required]
  # Capped at 300s (5 minutes) at runtime
  timeout_sec: 30

# --------------------------------------------------------------------------
# Export Worker (PDF/CSV generation) [mixed]
# --------------------------------------------------------------------------
export_worker:
  # Enable the export worker [restart-required]
  enabled: true
  # Poll interval for pending export jobs in seconds [hot-reloadable]
  poll_interval_sec: 5
  # Number of rows per page during export generation [hot-reloadable]
  page_size: 1000
  # Presigned download URL expiry in seconds [hot-reloadable]
  # Capped at 604800 (7 days, S3 maximum) at runtime
  presign_expiry_sec: 3600  # 1 hour

# --------------------------------------------------------------------------
# Cleanup Worker (expired file removal) [mixed]
# --------------------------------------------------------------------------
cleanup_worker:
  # Enable the cleanup worker [restart-required]
  enabled: true
  # Run interval in seconds [hot-reloadable]
  interval_sec: 3600  # 1 hour
  # Number of files to process per batch [hot-reloadable]
  batch_size: 100
  # Grace period after expiry before deletion in seconds [hot-reloadable]
  # Allows presigned download URLs to complete before removing files
  grace_period_sec: 3600  # 1 hour

# --------------------------------------------------------------------------
# Scheduler Worker (cron-based) [hot-reloadable]
# --------------------------------------------------------------------------
scheduler:
  # Scheduler poll interval in seconds [hot-reloadable]
  interval_sec: 60  # 1 minute

# --------------------------------------------------------------------------
# Archival Worker (audit log archival) [mixed]
# --------------------------------------------------------------------------
archival:
  # Enable the archival worker [restart-required]
  enabled: false
  # Run interval in hours [hot-reloadable]
  interval_hours: 24
  # Days to retain audit logs in hot storage (PostgreSQL) [hot-reloadable]
  hot_retention_days: 90
  # Months to retain in warm storage (S3 Standard) [hot-reloadable]
  warm_retention_months: 24
  # Months to retain in cold storage (S3 Glacier) [hot-reloadable]
  cold_retention_months: 84  # 7 years
  # Records per archival batch [hot-reloadable]
  batch_size: 5000
  # S3 key prefix for archived audit logs [restart-required]
  storage_prefix: "archives/audit-logs"
  # S3 storage class for archived objects [restart-required]
  storage_class: "GLACIER"
  # Number of future partitions to create ahead of time [hot-reloadable]
  partition_lookahead: 3
  # Presigned download URL expiry for archived files in seconds [hot-reloadable]
  # Capped at 604800 (7 days, S3 maximum) at runtime
  presign_expiry_sec: 3600  # 1 hour
