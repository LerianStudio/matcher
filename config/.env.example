# Matcher Service Configuration
# Copy this file to .env and customize for your environment

#-------------------------------------------------------
# Application Settings
#-------------------------------------------------------
ENV_NAME=development
LOG_LEVEL=info
# Terminate TLS at ingress in production
SERVER_ADDRESS=:4018
# default 100MB, raise cautiously
HTTP_BODY_LIMIT_BYTES=104857600

# Use explicit origins in production (no wildcard)
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Origin,Content-Type,Accept,Authorization,X-Request-ID

# TLS Configuration (optional - terminate TLS at ingress in production)
# SERVER_TLS_CERT_FILE=
# SERVER_TLS_KEY_FILE=

# Set to true when TLS is terminated by a load balancer/reverse proxy.
# Enables HSTS headers even without local TLS certs.
TLS_TERMINATED_UPSTREAM=false
# Comma-separated trusted proxy addresses/CIDRs for client IP resolution.
# TRUSTED_PROXIES=

# Single-tenant defaults (must be valid UUID)
DEFAULT_TENANT_ID=11111111-1111-1111-1111-111111111111
DEFAULT_TENANT_SLUG=default

#-------------------------------------------------------
# PostgreSQL Primary Database
#-------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=matcher

# Use strong secrets in production
POSTGRES_PASSWORD=matcher_dev_password
POSTGRES_DB=matcher

# Use require/verify-full in production
POSTGRES_SSLMODE=disable

# Migrations path (container path)
MIGRATIONS_PATH=migrations

# Connection Pool
POSTGRES_MAX_OPEN_CONNS=25
POSTGRES_MAX_IDLE_CONNS=5

# Max connection lifetime in minutes (prevents stale connections under load)
POSTGRES_CONN_MAX_LIFETIME_MINS=30

# Max idle time in minutes (closes idle connections to free resources)
POSTGRES_CONN_MAX_IDLE_TIME_MINS=5

# Per-connection timeout in seconds (applied via DSN connect_timeout)
POSTGRES_CONNECT_TIMEOUT_SEC=10

# Maximum time (seconds) for any database query/transaction to complete.
# Prevents indefinite hangs when the connection pool is exhausted.
# Applied as a context deadline on all database operations.
# Set to 0 to use the default (30 seconds).
POSTGRES_QUERY_TIMEOUT_SEC=30

#-------------------------------------------------------
# Infrastructure Boot Timeout
#-------------------------------------------------------
# Maximum time for all infrastructure connections (PG, Redis, RabbitMQ) during startup.
# If this timeout is exceeded, the application will fail to start.
# Set lower in container orchestration for faster failure detection.
INFRA_CONNECT_TIMEOUT_SEC=30
# Per-dependency readiness timeout in seconds.
HEALTH_CHECK_TIMEOUT_SEC=5

#-------------------------------------------------------
# PostgreSQL Replica (Optional - for CQRS read scaling)
#-------------------------------------------------------
# When configured, all CQRS query operations (GET endpoints) are routed
# to the read replica, reducing load on the primary database.
# If not configured, queries automatically fall back to the primary.
#
# Only needed when a read-replica is running; the app falls back to the primary DB when not set.
# Leave empty or commented out for local development.
# POSTGRES_REPLICA_HOST=localhost
# POSTGRES_REPLICA_PORT=5433
# POSTGRES_REPLICA_USER=        # Falls back to POSTGRES_USER if empty
# POSTGRES_REPLICA_PASSWORD=    # Falls back to POSTGRES_PASSWORD if empty
# POSTGRES_REPLICA_DB=          # Falls back to POSTGRES_DB if empty
# POSTGRES_REPLICA_SSLMODE=     # Falls back to POSTGRES_SSLMODE if empty

#-------------------------------------------------------
# PostgreSQL Replication (for primary-replica setup)
#-------------------------------------------------------
# Password for the 'replicator' user used for streaming replication.
# Required when using docker-compose with postgres-replica service.
REPLICATOR_PASSWORD=replicator_secure_password
# CIDR range allowed for replication connections (defaults to Docker network)
# REPLICATION_CIDR=172.16.0.0/12

#-------------------------------------------------------
# Redis
#-------------------------------------------------------
REDIS_HOST=localhost:6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_PROTOCOL=3
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=2
REDIS_READ_TIMEOUT_MS=3000
REDIS_WRITE_TIMEOUT_MS=3000
REDIS_DIAL_TIMEOUT_MS=5000
# REDIS_MASTER_NAME=  # For Sentinel mode
# REDIS_TLS=false     # Set true in production
# REDIS_CA_CERT=

#-------------------------------------------------------
# RabbitMQ
#-------------------------------------------------------
# Use amqps in production
RABBITMQ_URI=amqp
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
# Matches docker-compose credentials (code default: guest)
RABBITMQ_USER=matcher_admin
RABBITMQ_PASSWORD=matcher_dev_password
RABBITMQ_VHOST=/
RABBITMQ_HEALTH_URL=http://localhost:15672
# Enables HTTP health checks only in non-production and only for local/internal hosts.
# Intended for local docker-compose and private cluster service names.
# Public/external HTTP endpoints are rejected even when this flag is true.
RABBITMQ_ALLOW_INSECURE_HEALTH_CHECK=false

#-------------------------------------------------------
# Authentication (lib-auth)
#-------------------------------------------------------
AUTH_ENABLED=false
AUTH_SERVICE_ADDRESS=http://localhost:8081
# AUTH_JWT_SECRET=  # Required when AUTH_ENABLED=true

#-------------------------------------------------------
# API Documentation (Swagger)
#-------------------------------------------------------
# Disabled by default. Set to true for development convenience.
# A warning is logged if enabled in production (and it is force-disabled).
SWAGGER_ENABLED=false

# Override the host shown in the Swagger spec (e.g., "api.example.com").
# When empty, Swagger UI defaults to the request's own host, which is
# correct for most local and containerized setups.
# Set this behind a reverse proxy or API gateway where the public hostname
# differs from the internal one.
# SWAGGER_HOST=

# Schemes advertised in the Swagger spec (comma-separated, e.g., "http,https").
# Defaults to "https" so the spec never advertises plain HTTP unless opted in.
SWAGGER_SCHEMES=https

#-------------------------------------------------------
# Multi-Tenancy
#-------------------------------------------------------
MULTI_TENANT_INFRA_ENABLED=false

#-------------------------------------------------------
# OpenTelemetry
#-------------------------------------------------------
ENABLE_TELEMETRY=false
OTEL_LIBRARY_NAME=github.com/LerianStudio/matcher
OTEL_RESOURCE_SERVICE_NAME=matcher
OTEL_RESOURCE_SERVICE_VERSION=1.0.0
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
OTEL_RESOURCE_DEPLOYMENT_ENVIRONMENT=development

#-------------------------------------------------------
# Rate Limiting
#-------------------------------------------------------
# Set to false to disable rate limiting (e.g., for e2e tests)
RATE_LIMIT_ENABLED=true
# Max requests per window
RATE_LIMIT_MAX=100
# Window duration in seconds
RATE_LIMIT_EXPIRY_SEC=60

#-------------------------------------------------------
# Webhook Dispatch
#-------------------------------------------------------
# Default HTTP timeout for webhook dispatches (seconds).
# Individual webhooks may override this via the admin API in the future.
# Capped at 300 seconds (5 minutes). Default: 30 seconds.
WEBHOOK_TIMEOUT_SEC=30

# Export-specific rate limiting (stricter to prevent resource exhaustion)
# Max export requests per window
EXPORT_RATE_LIMIT_MAX=10
# Window duration in seconds
EXPORT_RATE_LIMIT_EXPIRY_SEC=60

# Dispatch rate limiting (protects external system integrations)
# Max dispatch requests per window
DISPATCH_RATE_LIMIT_MAX=50
# Window duration in seconds
DISPATCH_RATE_LIMIT_EXPIRY_SEC=60

#-------------------------------------------------------
# Observability & Metrics
#-------------------------------------------------------
# Database connection pool metrics collection interval (seconds)
# Lower values = more granular monitoring, higher overhead
DB_METRICS_INTERVAL_SEC=15

#-------------------------------------------------------
# Idempotency & Deduplication
#-------------------------------------------------------
# How long failed operations remain blocked before retry (seconds)
# Prevents immediate retries while allowing eventual recovery
# 5 minutes
IDEMPOTENCY_RETRY_WINDOW_SEC=300

# How long completed idempotency keys remain cached (hours)
# Duplicate requests within this window return the cached response
# 7 days
IDEMPOTENCY_SUCCESS_TTL_HOURS=168

# HMAC secret for server-side signing of idempotency keys before Redis storage.
# Prevents key prediction attacks by making stored keys unpredictable.
# When empty, keys are stored unsigned (backward compatible).
# SECURITY: Use a strong, random secret in production (minimum 32 bytes).
# IDEMPOTENCY_HMAC_SECRET=

# TTL for deduplication keys in Redis (seconds)
# Safety net to prevent zombie locks from blocking retries forever
# 1 hour
DEDUPE_TTL_SEC=3600

#-------------------------------------------------------
# Callback Rate Limiting
#-------------------------------------------------------
# Maximum callbacks per external system per minute.
# Each integration (JIRA, WEBHOOK, SERVICENOW, etc.) gets its own budget.
# Prevents callback flooding attacks while allowing legitimate burst traffic.
CALLBACK_RATE_LIMIT_PER_MIN=60

#-------------------------------------------------------
# Object Storage (S3-compatible: AWS S3, MinIO, SeaweedFS)
#-------------------------------------------------------
# SeaweedFS default for local development
OBJECT_STORAGE_ENDPOINT=http://localhost:8333
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_BUCKET=matcher-exports
# OBJECT_STORAGE_ACCESS_KEY_ID=
# OBJECT_STORAGE_SECRET_ACCESS_KEY=
# Required for SeaweedFS/MinIO
OBJECT_STORAGE_USE_PATH_STYLE=true

#-------------------------------------------------------
# Cleanup Worker (Expired Data)
#-------------------------------------------------------
# Background cleanup worker for expired data
CLEANUP_WORKER_ENABLED=true

#-------------------------------------------------------
# Archival Worker (Audit Log Retention)
#-------------------------------------------------------
ARCHIVAL_WORKER_ENABLED=false
# How often the archival worker runs
ARCHIVAL_WORKER_INTERVAL_HOURS=24
# Keep recent logs in hot storage
ARCHIVAL_HOT_RETENTION_DAYS=90
# Keep in warm/compressed storage
ARCHIVAL_WARM_RETENTION_MONTHS=24
# Keep in cold/archive storage (7 years)
ARCHIVAL_COLD_RETENTION_MONTHS=84
# Records per archival batch
ARCHIVAL_BATCH_SIZE=5000
# Required when ARCHIVAL_WORKER_ENABLED=true
ARCHIVAL_STORAGE_BUCKET=matcher-archive
ARCHIVAL_STORAGE_PREFIX=archives/audit-logs
ARCHIVAL_STORAGE_CLASS=GLACIER
# Months of partitions to pre-create
ARCHIVAL_PARTITION_LOOKAHEAD=3
# How long archive download URLs remain valid
ARCHIVAL_PRESIGN_EXPIRY_SEC=3600

#-------------------------------------------------------
# Export Worker
#-------------------------------------------------------
EXPORT_WORKER_ENABLED=true
# How long download URLs remain valid (1 hour)
EXPORT_PRESIGN_EXPIRY_SEC=3600
# Records per page during streaming
EXPORT_WORKER_PAGE_SIZE=1000
# How often to check for queued jobs
EXPORT_WORKER_POLL_INTERVAL_SEC=5

#-------------------------------------------------------
# Scheduler Worker (Cron-Based Matching)
#-------------------------------------------------------
# How often the scheduler worker checks for due schedules (seconds).
# Lower values = more responsive schedule execution, higher overhead.
# Default: 60 seconds (1 minute).
SCHEDULER_INTERVAL_SEC=60

#-------------------------------------------------------
# E2E Fuzz Testing (Fee Schedule Adversarial Tests)
#-------------------------------------------------------
# Enable Claude-powered adversarial test oracle.
# When true, the fuzz test suite uses the Anthropic API to generate
# adversarial fee schedule scenarios and independently compute expected
# results. Requires ANTHROPIC_API_KEY to be set.
# Default: false (only deterministic Go oracle runs)
E2E_CLAUDE_ORACLE=false

# Anthropic API key for the Claude oracle.
# Required when E2E_CLAUDE_ORACLE=true.
# ANTHROPIC_API_KEY=

# Claude model for oracle calculations.
# Haiku is recommended for cost efficiency (pure arithmetic).
# Default: claude-sonnet-4-20250514
E2E_CLAUDE_MODEL=claude-sonnet-4-20250514

# Number of adversarial scenarios Claude generates per fuzz run.
# Higher values = more coverage, higher API cost.
# Default: 20
E2E_FUZZ_SCENARIOS=20

# Path to a JSON artifact file for replay mode.
# When set, the fuzz test replays scenarios from this file instead
# of generating new ones. No Claude API calls are made in replay mode.
# E2E_FUZZ_REPLAY=

# Directory for fuzz test artifacts (run logs, failure files).
# Relative to the test package directory (tests/e2e/journeys/).
# Default: fuzz_artifacts
E2E_FUZZ_ARTIFACT_DIR=fuzz_artifacts

# Enable verbose logging (includes Claude reasoning on PASS scenarios).
# Default: false (only logs reasoning on FAIL)
E2E_FUZZ_VERBOSE=false
